<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <UI Id="WixUI_OTGuru">
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Title"  FaceName="Tahoma" Size="9" Bold="yes" />
      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

      <DialogRef Id="CancelDlg" />
      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />
      <DialogRef Id="WelcomeDlg" />
      <DialogRef Id="MaintenanceWelcomeDlg" />
      <DialogRef Id="MaintenanceTypeDlg" />
      <DialogRef Id="VerifyReadyDlg" />

      <!-- WelcomeDlg → TokenDlg → VerifyReadyDlg -->
      <Publish Dialog="WelcomeDlg"     Control="Next"    Event="NewDialog"   Value="TokenDlg"      Condition="1" />

      <Publish Dialog="TokenDlg"       Control="Next"    Event="SpawnDialog" Value="TokenRequiredDlg" Order="1" Condition="NOT TOKEN OR TOKEN=&quot;&quot;" />
      <Publish Dialog="TokenDlg"       Control="Next"    Event="NewDialog"   Value="VerifyReadyDlg"   Order="2" Condition="TOKEN&lt;&gt;&quot;&quot;" />
      <Publish Dialog="TokenDlg"       Control="Back"    Event="NewDialog"   Value="WelcomeDlg"     Condition="1" />
      <Publish Dialog="TokenDlg"       Control="Cancel"  Event="SpawnDialog" Value="CancelDlg"      Condition="1" />

      <Publish Dialog="VerifyReadyDlg" Control="Back"    Event="NewDialog"   Value="TokenDlg"       Condition="NOT Installed" />
      <Publish Dialog="VerifyReadyDlg" Control="Back"    Event="NewDialog"   Value="MaintenanceTypeDlg" Condition="Installed AND NOT PATCH" />
      <Publish Dialog="VerifyReadyDlg" Control="Back"    Event="NewDialog"   Value="WelcomeDlg"     Condition="Installed AND PATCH" />

      <!-- Maintenance flow -->
      <Publish Dialog="MaintenanceWelcomeDlg" Control="Next"         Event="NewDialog" Value="MaintenanceTypeDlg" Condition="1" />
      <Publish Dialog="MaintenanceTypeDlg"    Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg"     Condition="1" />
      <Publish Dialog="MaintenanceTypeDlg"    Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg"     Condition="1" />
      <Publish Dialog="MaintenanceTypeDlg"    Control="Back"         Event="NewDialog" Value="MaintenanceWelcomeDlg" Condition="1" />

      <InstallUISequence>
        <Show Dialog="ResumeDlg"    Before="ProgressDlg" Condition="Resume" />
        <Show Dialog="WelcomeDlg"   Before="ProgressDlg" Condition="NOT Installed AND NOT Resume" />
        <Show Dialog="MaintenanceWelcomeDlg" Before="ProgressDlg" Condition="Installed AND NOT Resume" />
      </InstallUISequence>

      <Dialog Id="TokenDlg" Width="370" Height="270" Title="OTGuru Agent — Токен активации">
        <Control Id="Title" Type="Text" X="15" Y="15" Width="340" Height="20"
                 Transparent="yes" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Title}Токен активации" />
        </Control>
        <Control Id="Description" Type="Text" X="25" Y="40" Width="320" Height="30" NoPrefix="yes">
          <Text Value="Введите токен активации. Без токена продолжить установку нельзя." />
        </Control>
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 TabSkip="yes" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine"  Type="Line"   X="0" Y="44"  Width="370" Height="0" />
        <Control Id="BottomLine"  Type="Line"   X="0" Y="234" Width="370" Height="0" />

        <Control Id="TokenLabel" Type="Text" X="25" Y="90" Width="100" Height="15" NoPrefix="yes">
          <Text Value="Токен:" />
        </Control>
        <Control Id="TokenEdit" Type="Edit" X="25" Y="105" Width="320" Height="20"
                 Property="TOKEN" Text="{200}" />

        <Control Id="Back"   Type="PushButton" X="156" Y="243" Width="56"  Height="17" Text="&amp;Назад" />
        <Control Id="Next"   Type="PushButton" X="214" Y="243" Width="56"  Height="17" Default="yes" Text="&amp;Далее" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56"  Height="17" Cancel="yes" Text="Отмена" />
      </Dialog>

      <Dialog Id="TokenRequiredDlg" Width="260" Height="95" Title="OTGuru Agent — Токен">
        <Control Id="Message" Type="Text" X="15" Y="15" Width="230" Height="40" NoPrefix="yes">
          <Text Value="Введите токен активации, чтобы продолжить." />
        </Control>
        <Control Id="OK" Type="PushButton" X="102" Y="60" Width="56" Height="17" Default="yes" Text="ОК">
          <Publish Event="EndDialog" Value="Return" />
        </Control>
      </Dialog>
    </UI>
  </Fragment>
</Wix>
