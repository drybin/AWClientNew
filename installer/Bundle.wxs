<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">

  <Bundle Name="CtrlDesk"
          Version="1.0.0"
          Manufacturer="CtrlDesk"
          UpgradeCode="6C0D5E4F-3A7B-6C0D-BE4F-5A7B8C0D5E4F">

    <BootstrapperApplication>
      <bal:WixInternalUIBootstrapperApplication />
    </BootstrapperApplication>

    <Chain>
      <!-- Always show MSI internal UI to avoid silent maintenance/reinstall flows -->
      <MsiPackage SourceFile="OTGuruAgent.msi"
                  bal:DisplayInternalUICondition="1" />
    </Chain>

  </Bundle>

</Wix>
