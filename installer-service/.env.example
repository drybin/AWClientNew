# Required
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-org
GITHUB_REPO=AWClientNew

# Optional (defaults shown)
INSTALLER_DIR=/data/installers
INSTALLER_TTL_HOURS=72

